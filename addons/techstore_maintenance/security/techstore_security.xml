<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_techstore_maintenance_category" model="ir.module.category">
            <name>TechStore Maintenance</name>
            <field name="description">Helps you manage your technical maintenance and technicians.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_techstore_technician" model="res.groups">
            <name>Technician</name>
            <field name="category_id" ref="module_techstore_maintenance_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_techstore_supervisor" model="res.groups">
            <name>Supervisor Técnico</name>
            <field name="category_id" ref="module_techstore_maintenance_category"/>
            <field name="implied_ids" eval="[(4, ref('group_techstore_technician'))]"/>
        </record>

        <record id="group_techstore_admin" model="res.groups">
            <name>Administrador Técnico</name>
            <field name="category_id" ref="module_techstore_maintenance_category"/>
            <field name="implied_ids" eval="[(4, ref('group_techstore_supervisor'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Record Rule for Technicians -->
        <record id="rule_techstore_maintenance_technician" model="ir.rule">
            <name>Technicians: See only assigned maintenance</name>
            <model_id ref="model_techstore_maintenance"/>
            <domain_force>[('technician_id.user_id', '=', user.id)]</domain_force>
            <groups eval="[(4, ref('group_techstore_technician'))]"/>
            <perm_read eval="True"/>
            <perm_write eval="True"/>
            <perm_create eval="True"/>
            <perm_unlink eval="False"/>
        </record>

        <!-- Rule for Admin/Supervisor: See everything -->
        <record id="rule_techstore_maintenance_all" model="ir.rule">
            <name>Admin/Supervisor: See all maintenance</name>
            <model_id ref="model_techstore_maintenance"/>
            <domain_force>[(1, '=', 1)]</domain_force>
            <groups eval="[(4, ref('group_techstore_supervisor')), (4, ref('group_techstore_admin'))]"/>
        </record>
    </data>
</odoo>
